CompileFlags:
  # Where to find compile_commands.json (generated by the SITL build)
  CompilationDatabase: build/px4_sitl_default

  # Strip flags clangd doesn't recognise (avoids spurious warnings)
  Remove:
    - -fno-strength-reduce
    - -fmerge-all-constants
    - -fno-builtin-printf
    - -fdiagnostics-color=*
